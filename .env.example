# For local development only. On Railway, set these in the
# Variables tab — the values never go to your GitHub repo.

# Yoco SECRET key (sk_test_... while building, sk_live_... when live)
YOCO_SECRET_KEY=sk_test_paste_yours_here

# Discord webhook URL — every completed order is posted here.
# Get one from Discord: channel settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/YYY

# Port (Railway sets this automatically; locally it defaults to 8080)
PORT=8080

# Public address of the site, with or without https://
BASE_URL=http://localhost:8080

# Template for local development.
# On Railway, set these in the Variables tab instead of in a .env file.

# Your Yoco SECRET key (server-side only)
YOCO_SECRET_KEY=sk_test_paste_yours_here

# Admin PIN
ADMIN_PIN=2026

# Port (Railway sets this automatically; locally it defaults to 8080)
PORT=8080

# Public URL of the site, with or without https:// — the server normalises it.
# Locally:  http://localhost:8080
# Live:     www.yourdomain.co.za  (https:// added automatically)
BASE_URL=http://localhost:8080

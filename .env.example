# Template for .env — copy this file, rename the copy to ".env",
# and fill in your own values. (.env is git-ignored so your secret
# key never ends up in your code or on GitHub.)

# Yoco SECRET key — server-side only, NEVER in browser code.
# sk_test_... while building (no real money), sk_live_... to launch.
YOCO_SECRET_KEY=sk_test_paste_yours_here

# PIN for the admin page
ADMIN_PIN=2026

# Port the website runs on
PORT=3000

# Public address of your site — Yoco redirects customers back here.
# localhost while testing, your real domain once hosted.
BASE_URL=http://localhost:3000
